# 环境变量配置
# 复制此文件为 .env 并填入实际值

# ===== 应用配置 =====
NODE_ENV=production
PORT=3000

# ===== 认证配置 =====
# HMAC 签名密钥（生产环境必须设置，不能使用默认值）
AUTH_SECRET=your-secret-here-change-me

# ===== CORS 配置 =====
# 允许的跨域来源，多个用逗号分隔
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ===== 日志配置 =====
LOG_LEVEL=info

# ===== 速率限制 =====
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# ===== 数据库配置 =====
# SQLite 数据库文件路径（相对于项目根目录）
DB_PATH=./notifications.db
